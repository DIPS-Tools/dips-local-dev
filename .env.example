# Firebase Emulator Configuration
# Set to 'true' for local development with Firebase Emulator (default)
# Set to 'false' for production Firebase
USE_EMULATOR=true

# Note: When USE_EMULATOR=false, ensure you have valid Firebase credentials:
# - upconsent/firebase-admin-key.json (production credentials)
# - upconsent/.env.local (with production API keys)
